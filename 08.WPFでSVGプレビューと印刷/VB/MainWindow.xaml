<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Reports.net - SVG プレビュー" Height="800" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#007ACC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ツールバー -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="6,4">
            <DockPanel>
                <!-- 左: 帳票選択 + 帳票生成ボタン -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="4,0">
                    <Border Background="#3E3E42" CornerRadius="3" Padding="4,0" Margin="0,0,6,0"
                            VerticalAlignment="Center">
                        <ComboBox x:Name="cmbReport" Width="160" FontSize="13"
                                  SelectedIndex="3" VerticalContentAlignment="Center"
                                  Foreground="#333" BorderThickness="0">
                            <ComboBoxItem Content="単純なサンプル"/>
                            <ComboBoxItem Content="10の倍数"/>
                            <ComboBoxItem Content="郵便番号"/>
                            <ComboBoxItem Content="見積書"/>
                            <ComboBoxItem Content="請求書"/>
                            <ComboBoxItem Content="商品一覧"/>
                        </ComboBox>
                    </Border>
                    <Button x:Name="btnGenerate" Click="BtnGenerate_Click"
                            ToolTip="帳票を生成してプレビュー"
                            Style="{StaticResource ToolbarButton}" Width="100">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="帳票生成" Foreground="White" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 中央: ページナビゲーション -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,0">
                    <Button x:Name="btnFirst" Click="BtnFirst_Click" ToolTip="最初のページ"
                            Style="{StaticResource ToolbarButton}">
                        <Path Data="M1,1 H3 V15 H1 Z M13,1 L5,8 L13,15 Z" Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="btnPrev" Click="BtnPrev_Click" ToolTip="前のページ"
                            Style="{StaticResource ToolbarButton}">
                        <Path Data="M13,1 L3,8 L13,15 Z" Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                    </Button>

                    <Border Background="#3E3E42" CornerRadius="3" Padding="8,2" Margin="6,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox x:Name="txtPage" Width="40" Text="0" TextAlignment="Center"
                                     FontSize="13" Foreground="White" Background="#1E1E1E"
                                     BorderBrush="#555" BorderThickness="1" VerticalContentAlignment="Center"
                                     KeyDown="TxtPage_KeyDown"/>
                            <TextBlock x:Name="lblTotal" Text=" / 0" Foreground="#CCC"
                                       FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="btnNext" Click="BtnNext_Click" ToolTip="次のページ"
                            Style="{StaticResource ToolbarButton}">
                        <Path Data="M3,1 L13,8 L3,15 Z" Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="btnLast" Click="BtnLast_Click" ToolTip="最終ページ"
                            Style="{StaticResource ToolbarButton}">
                        <Path Data="M3,1 L11,8 L3,15 Z M13,1 H15 V15 H13 Z" Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                    </Button>
                </StackPanel>

                <!-- 右: ズーム＆印刷 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="4,0">
                    <Button x:Name="btnZoomOut" Click="BtnZoomOut_Click" ToolTip="縮小"
                            Style="{StaticResource ToolbarButton}">
                        <TextBlock Text="&#xE71F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White"/>
                    </Button>
                    <Border Background="#3E3E42" CornerRadius="3" Padding="6,2" Margin="2,0">
                        <TextBlock x:Name="lblZoom" Text="100%" Foreground="#CCC"
                                   FontSize="12" VerticalAlignment="Center" MinWidth="36" TextAlignment="Center"/>
                    </Border>
                    <Button x:Name="btnZoomOut2" Click="BtnZoomIn_Click" ToolTip="拡大"
                            Style="{StaticResource ToolbarButton}">
                        <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White"/>
                    </Button>

                    <Border Width="1" Background="#555" Margin="10,4"/>

                    <Button x:Name="btnPrintPage" Click="BtnPrintPage_Click" ToolTip="このページを印刷"
                            Style="{StaticResource ToolbarButton}">
                        <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White"/>
                    </Button>
                    <Button x:Name="btnPrintAll" Click="BtnPrintAll_Click" ToolTip="全ページ印刷"
                            Style="{StaticResource ToolbarButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="全" Foreground="#AAA" FontSize="10"
                                       VerticalAlignment="Bottom" Margin="1,0,0,1"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- WebView2 プレビュー領域 -->
        <wv2:WebView2 x:Name="webView" Grid.Row="1"
                      DefaultBackgroundColor="Gainsboro"/>

        <!-- ステータスバー -->
        <Border Grid.Row="2" Background="#007ACC" Padding="8,3">
            <TextBlock x:Name="lblStatus" Text="帳票を生成してください" Foreground="White" FontSize="12"/>
        </Border>
    </Grid>
</Window>
